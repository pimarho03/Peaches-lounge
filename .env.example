# Peaches Lounge — environment variables
# Copy this file to `.env.local` and fill in real values. `.env*` is gitignored
# (except this example), so your secrets never get committed.

# Google OAuth (Sign in with Google)
# Create these in Google Cloud Console:
#   APIs & Services → Credentials → Create credentials → OAuth client ID
#   Application type: Web application
#   Authorized redirect URI:
#     http://localhost:3000/api/auth/sso/google/callback
#   (add your production URL's /api/auth/sso/google/callback too)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# App surfaces gate (login/signup/dashboard/staff/admin pages + their API
# routes). "on" re-enables them for local dev; any other value (including
# unset, the production default) keeps them gated behind a redirect/404 so
# the deployed site is brand-only until the iOS app launches.
APP_SURFACES=on
